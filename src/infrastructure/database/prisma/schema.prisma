generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  perfil       Perfil
  bairro       String?
  ativo        Boolean  @default(true)
  createdAt    DateTime @default(now())
  uploads      Upload[]
}

model Upload {
  id             String    @id
  fileName       String
  condition      Condition
  totalRecords   Int
  createdAt      DateTime
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  aggregateBuckets AggregateBucket[]

  @@index([createdAt])
  @@index([userId])
}

model AggregateBucket {
  id                                String    @id @default(cuid())
  condition                         Condition
  ageGroup                          String?
  sex                               String?
  raceColor                         String?
  familyAllowance                   Boolean?
  neighborhood                      String?
  needsMedicalCare                  Boolean
  needsNursingCare                  Boolean
  needsHomeVisit                    Boolean
  hasStaleBloodPressureMeasurement  Boolean
  hasStaleHbA1c                     Boolean
  count                             Int
  uploadId                          String
  upload                            Upload    @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([uploadId])
  @@index([condition])
  @@index([neighborhood])
}

enum Perfil {
  ENFERMEIRO
  MEDICO
  GESTOR
  ACS
}

enum Condition {
  DIABETES
  HYPERTENSION
}
