generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  perfil       Perfil
  bairro       String?
  ativo        Boolean  @default(true)
  createdAt    DateTime @default(now())
  uploads      Upload[]
}

model Upload {
  id                               String            @id
  fileName                         String
  condition                        Condition
  totalRecords                     Int
  supportsMedicalTimeline          Boolean           @default(false)
  supportsNursingTimeline          Boolean           @default(false)
  supportsDentalTimeline           Boolean           @default(false)
  supportsHomeVisitTimeline        Boolean           @default(false)
  supportsBmiClassification        Boolean           @default(false)
  supportsBloodPressureClassification Boolean        @default(false)
  supportsHbA1cClassification      Boolean           @default(false)
  createdAt                        DateTime
  userId                           String
  user                             User              @relation(fields: [userId], references: [id])
  aggregateBuckets                 AggregateBucket[]
  careEventBuckets                 CareEventBucket[]

  @@index([createdAt])
  @@index([userId])
}

model AggregateBucket {
  id                                String    @id @default(cuid())
  condition                         Condition
  ageGroup                          String?
  sex                               String?
  raceColor                         String?
  ibgeRaceColor                     String?
  familyAllowance                   Boolean?
  neighborhood                      String?
  needsMedicalCare                  Boolean
  needsNursingCare                  Boolean
  needsDentalCare                   Boolean   @default(false)
  needsHomeVisit                    Boolean
  hasStaleBloodPressureMeasurement  Boolean
  hasStaleHbA1c                     Boolean
  bmiClassification                 String?
  bloodPressureClassification       String?
  hba1cClassification               String?
  count                             Int
  uploadId                          String
  upload                            Upload    @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([uploadId])
  @@index([condition])
  @@index([neighborhood])
}

model CareEventBucket {
  id              String    @id @default(cuid())
  condition       Condition
  profession      String
  eventDate       DateTime
  ageGroup        String?
  sex             String?
  raceColor       String?
  ibgeRaceColor   String?
  familyAllowance Boolean?
  neighborhood    String?
  count           Int
  uploadId        String
  upload          Upload    @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([uploadId])
  @@index([profession])
  @@index([eventDate])
}

enum Perfil {
  ENFERMEIRO
  MEDICO
  GESTOR
  ACS
}

enum Condition {
  DIABETES
  HYPERTENSION
  MIXED
}
